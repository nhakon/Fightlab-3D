  // ---------- Hierarchical skeleton (FK/CCD IK) ----------
  const IDX = {
    root: 0,
    hipL: 1, kneeL: 2, footL: 3,
    hipR: 4, kneeR: 5, footR: 6,
    spine: 7,
    shoulderL: 8, elbowL: 9, handL: 10,
